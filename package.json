{
  "name": "edn-to-js",
  "version": "1.0.1",
  "description": "EDN to JS",
  "type": "module",
  "bin": {
    "json-to-edn": "./dist/json-to-clj.cjs",
    "edn-to-json": "./dist/clj-to-json.cjs"
  },
  "exports": {
    ".": "./dist/main.js"
  },
  "main": "dist/main.js",
  "scripts": {
    "watch": "shadow-cljs watch app",
    "compile": "shadow-cljs compile app",
    "build": "shadow-cljs release app",
    "build-json-to-clj-cli": "shadow-cljs release json-to-clj-cli",
    "build-clj-to-json-cli": "shadow-cljs release clj-to-json-cli",
    "prepare": "npm run build && npm run build-json-to-clj-cli && npm run build-clj-to-json-cli"
  },
  "keywords": [],
  "author": "Mac Heller-Ogden",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/machellerogden/edn-to-js.git"
  },
  "devDependencies": {
    "shadow-cljs": "^3.3.6"
  }
}
